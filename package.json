{
  "name": "teststampinup",
  "version": "1.0.0",
  "description": "Manual and automated test coverage for account creation and profile management on stampinup.com, implemented using Playwright.",
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "scripts": {
    "test": "npx playwright test",
    "test:ui": "npx playwright test --ui tests",
    "test:headed": "npx playwright test --headed",
    "codegen": "npx playwright codegen https://www.stampinup.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/braydonlowe/testStampinUp.git"
  },
  "keywords": [],
