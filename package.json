  "type": "module",
  "bugs": {
    "url": "https://github.com/braydonlowe/testStampinUp/issues"
  },
  "homepage": "https://github.com/braydonlowe/testStampinUp#readme",
  "devDependencies": {
    "@playwright/test": "^1.58.2"
  }
}
